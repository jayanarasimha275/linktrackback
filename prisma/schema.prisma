generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  PUBLISHER
}

model User {
  id Int @id @default(autoincrement())

  name     String
  email    String @unique
  password String

  role Role @default(PUBLISHER)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  links Link[]

  @@map("users")
}

model Link {
  id             Int    @id @default(autoincrement())
  title          String
  shortCode      String @unique
  destinationUrl String

  isActive Boolean @default(true)

  // Owner
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Statistics
  clicks       Int @default(0)
  uniqueClicks Int @default(0)
  visitors     Int @default(0)
  conversions  Int @default(0)

  // Device Statistics
  mobileClicks  Int @default(0)
  desktopClicks Int @default(0)
  tabletClicks  Int @default(0)

  // Top Country
  topCountry String? @default("No data")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  clicksData Click[]

  @@index([userId])
  @@map("links")
}

model Click {
  id      Int     @id @default(autoincrement())
  clickId String? @unique @default(cuid())

  linkId Int
  link   Link @relation(fields: [linkId], references: [id], onDelete: Cascade)

  ipAddress String?
  visitorId String?
  cookieId  String?

  browser         String?
  browserVersion  String?
  operatingSystem String?
  deviceType      String?

  country String?
  city    String?

  referrer  String?
  userAgent String?

  isUnique Boolean @default(false)

  clickedAt DateTime @default(now())

  @@index([linkId, visitorId, ipAddress, browser, browserVersion, operatingSystem, deviceType])
}
